# Trade212 broker credentials (demo / paper trading only)
# Get these from https://www.trading212.com -> Settings -> API
TRADING212_API_KEY=your_api_key_here
TRADING212_SECRET_KEY=your_secret_key_here

# Must be "demo" — live trading is intentionally not supported here.
TRADING212_ENV=demo

# Base URL is auto-selected by broker.trade212_api from TRADING212_ENV.
# Override only if you know what you are doing.
# TRADING212_BASE_URL=https://demo.trading212.com/api/v0

# Market data (TradingView via tvdatafeed)
# Anonymous fetches are heavily rate-limited and return limited history.
# Paste the `sessionid` cookie from a logged-in tradingview.com browser tab
# (DevTools -> Application -> Cookies) to authenticate and lift those limits.
# Leave blank to use anonymous mode.
TV_SESSIONID=

# regime_trader runtime config
REGIME_TRADER_CONFIG=config/settings.yaml
REGIME_TRADER_LOG_LEVEL=INFO
